      "lessons": [
        {
          "id": "math_1_1", "title": "Sumar hasta 10", "titleEs": "Sumar hasta 10", "xpReward": 20,
          "theory": {
            "title": "La Suma: Juntar Cantidades",
            "explanation": "Sumar significa unir dos o más cantidades para obtener un total. El signo de suma es el + (más).",
            "grammar": "3 + 4 = 7 → tres más cuatro igual a siete\n0 + 5 = 5 → cero más cinco igual cinco\n5 + 5 = 10 → cinco más cinco igual diez\nPropiedad conmutativa: 3+4 = 4+3\nNeutro: cualquier número + 0 = mismo número",
            "vocabulary": [
              {"word":"Suma","translation":"Operación para unir","emoji":"➕","example":"3 + 4 = 7 es una suma."},
              {"word":"Sumandos","translation":"Números que se suman","emoji":"🔢","example":"En 3+4, los sumandos son 3 y 4."},
              {"word":"Resultado","translation":"Número final obtenido","emoji":"🎯","example":"En 3+4=7, el resultado es 7."},
              {"word":"Total","translation":"Suma de todo","emoji":"💯","example":"El total de 2+3+5 es 10."},
              {"word":"Más","translation":"Símbolo + de la suma","emoji":"➕","example":"Cinco más tres son ocho."},
              {"word":"Igual","translation":"Símbolo = resultado","emoji":"🟰","example":"Dos más dos igual cuatro."}
            ],
            "tip": "💡 Truco: Para sumar rápido, empieza con el número mayor. Ej: 7+3, empieza en 7 y cuenta 3 más."
          },
          "exercises": [
            { "type": "translate", "question": "¿Cuánto es 3 + 4?", "answer": "7", "options": ["7","6","8","9"], "xp": 3 },
            { "type": "visual", "question": "¿Cuántas estrellas hay?", "count": 5, "emoji": "⭐", "answer": "5", "options": ["4","5","6","7"], "xp": 5 },
            { "type": "translate", "question": "¿Cuánto es 5 + 5?", "answer": "10", "options": ["10","9","8","11"], "xp": 3 },
