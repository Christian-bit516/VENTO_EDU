            {"type":"translate","question":"¿Cuánto es 50 + 30?","answer":"80","options":["80","70","90","85"],"xp":4},
            {"type":"fillblank","sentence":"45 + ___ = 70","answer":"25","options":["25","15","30","20"],"xp":6},
