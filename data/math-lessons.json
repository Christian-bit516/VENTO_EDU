        {
          "id": "math_3_1", "title": "División Básica", "titleEs": "División Básica", "xpReward": 35,
          "theory": {
            "title": "División: Repartir en Partes Iguales",
            "explanation": "Dividir es repartir una cantidad en grupos iguales. Es la operación inversa de la multiplicación.",
            "grammar": "12 ÷ 4 = 3 → repartir 12 en 4 grupos = 3 en cada grupo\nDividendo ÷ Divisor = Cociente\n12 ÷ 4: 12=dividendo, 4=divisor, 3=cociente\nVerificación: 3 × 4 = 12 ✓\nDivisión exacta: sin residuo (sobrante)\nDivisión inexacta: con residuo",
            "vocabulary": [
              {"word":"División","translation":"Repartir en partes iguales","emoji":"➗","example":"12 ÷ 3 = 4 es una división."},
              {"word":"Dividendo","translation":"Número que se divide","emoji":"🔢","example":"En 12÷3, el dividendo es 12."},
              {"word":"Divisor","translation":"Entre cuánto se divide","emoji":"3️⃣","example":"En 12÷3, el divisor es 3."},
              {"word":"Cociente","translation":"Resultado de la división","emoji":"🎯","example":"En 12÷3=4, el cociente es 4."},
              {"word":"Residuo","translation":"Lo que sobra al dividir","emoji":"🔄","example":"11÷3=3 con residuo 2."},
              {"word":"Exacta","translation":"Sin residuo","emoji":"✅","example":"12÷4=3 es una división exacta."}
            ],
            "tip": "💡 Para dividir, usa la multiplicación al revés: ¿Cuánto × 4 = 20? Respuesta: 5. Entonces 20÷4=5."
          },
          "exercises": [
