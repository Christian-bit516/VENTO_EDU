        {
          "id": "math_1_2", "title": "Restar hasta 10", "titleEs": "Restar hasta 10", "xpReward": 20,
          "theory": {
            "title": "La Resta: Quitar Cantidades",
            "explanation": "Restar significa quitar una cantidad a otra. El signo de resta es el - (menos). El resultado siempre es menor o igual.",
            "grammar": "8 - 3 = 5 → ocho menos tres igual a cinco\n10 - 0 = 10 → cualquier número - 0 = mismo número\n5 - 5 = 0 → un número menos sí mismo = cero\nMinuendo - Sustraendo = Diferencia\nNO es conmutativa: 8-3 ≠ 3-8",
            "vocabulary": [
              {"word":"Resta","translation":"Operación para quitar","emoji":"➖","example":"10 - 4 = 6 es una resta."},
              {"word":"Minuendo","translation":"Número del que se resta","emoji":"🔟","example":"En 10-4, el minuendo es 10."},
              {"word":"Sustraendo","translation":"Número que se quita","emoji":"4️⃣","example":"En 10-4, el sustraendo es 4."},
              {"word":"Diferencia","translation":"Resultado de la resta","emoji":"🎯","example":"En 10-4=6, la diferencia es 6."},
              {"word":"Menos","translation":"Símbolo - de la resta","emoji":"➖","example":"Ocho menos tres son cinco."},
              {"word":"Verificar","translation":"Comprobar con suma","emoji":"✅","example":"Verifica: si 8-3=5, entonces 5+3=8."}
            ],
            "tip": "💡 Truco para verificar: si 9-4=5, comprueba sumando: 5+4=9. ¡Así sabes si está bien!"
          },
          "exercises": [
            {"type":"translate","question":"¿Cuánto es 9 - 4?","answer":"5","options":["5","4","6","3"],"xp":3},
            {"type":"translate","question":"¿Cuánto es 10 - 7?","answer":"3","options":["3","2","4","7"],"xp":3},
            {"type":"fillblank","sentence":"8 - ___ = 5","answer":"3","options":["3","4","2","5"],"xp":5},
            {"type":"speed","question":"¿Cuánto es 6 - 6?","answer":"0","options":["0","1","6","12"],"xp":5},
            {"type":"matching","instruction":"Une la resta con su resultado","pairs":[["10-3","7"],["8-4","4"],["7-2","5"],["5-1","4"]],"xp":6},
            {"type":"fillblank","sentence":"___ - 3 = 7","answer":"10","options":["10","9","8","6"],"xp":5},
            {"type":"translate","question":"En 9 - 5 = 4, ¿cuál es la diferencia?","answer":"4","options":["4","9","5","14"],"xp":4}
          ]
        },
        {
          "id": "math_1_3", "title": "Sumar y Restar hasta 100", "titleEs": "Sumar y Restar hasta 100", "xpReward": 30,
          "theory": {
            "title": "Operaciones con Números Grandes",
            "explanation": "Ahora extendemos suma y resta a números hasta 100. El truco es operar primero las unidades, luego las decenas.",
            "grammar": "Unidades = posición de la derecha (1-9)\nDecenas = posición del medio (10,20...90)\n35 + 24: primero 5+4=9, luego 3+2=5 → 59\n67 - 32: primero 7-2=5, luego 6-3=3 → 35\nLlevada: cuando la suma de unidades ≥ 10\nEj: 27+36: 7+6=13, escribes 3 y llevas 1",
            "vocabulary": [
              {"word":"Decenas","translation":"Múltiplos de 10","emoji":"🔟","example":"10, 20, 30, 40 son decenas."},
              {"word":"Unidades","translation":"Números del 1 al 9","emoji":"1️⃣","example":"En 35, el 5 son las unidades."},
              {"word":"Llevada","translation":"Cuando sumas y sobrepasas 9","emoji":"⬆️","example":"7+6=13, la llevada es el 1."},
              {"word":"Prestado","translation":"En resta cuando el de arriba es menor","emoji":"⬇️","example":"En 32-17, necesitas pedir prestado."},
              {"word":"Decena","translation":"Grupo de 10 unidades","emoji":"📦","example":"1 decena = 10 unidades."},
              {"word":"Centena","translation":"Grupo de 100 unidades","emoji":"💯","example":"1 centena = 10 decenas = 100 unidades."}
            ],
            "tip": "💡 Para sumar rápido números grandes, redondea a la decena más cercana: 48+35 ≈ 50+35=85, luego ajusta."
          },
          "exercises": [
