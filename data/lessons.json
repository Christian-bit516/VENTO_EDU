            { "type": "matching", "instruction": "Une las frases con su significado", "pairs": [["My name is","Mi nombre es"],["I'm from","Soy de"],["I'm a student","Soy estudiante"],["I live in","Vivo en"]], "xp": 5 },
            { "type": "fillblank", "sentence": "What is ___ name?", "answer": "your", "options": ["your","my","his","our"], "xp": 4 },
            { "type": "listen", "instruction": "Escucha y escribe", "text": "I am from Mexico", "answer": "I am from Mexico", "xp": 4 }
          ]
        }
