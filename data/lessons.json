        {
          "id": "lesson_1_3",
          "title": "My Name Is...",
          "titleEs": "Mi Nombre Es...",
          "xpReward": 25,
          "theory": {
            "title": "Presentarte en inglés",
            "explanation": "Hay dos formas principales de decir tu nombre en inglés.",
            "grammar": "My name is... → Mi nombre es...\nI am... / I'm... → Yo soy...\nWhat is your name? → ¿Cómo te llamas?\nWhere are you from? → ¿De dónde eres?\nI'm from... → Soy de...",
            "vocabulary": [
              { "word": "Name", "translation": "Nombre", "emoji": "📛", "example": "My name is Carlos." },
              { "word": "From", "translation": "De (origen)", "emoji": "🌍", "example": "I'm from Mexico." },
              { "word": "Years old", "translation": "Años de edad", "emoji": "🎂", "example": "I'm 15 years old." },
              { "word": "Student", "translation": "Estudiante", "emoji": "📚", "example": "I'm a student." },
              { "word": "Live", "translation": "Vivir", "emoji": "🏠", "example": "I live in Monterrey." },
              { "word": "Speak", "translation": "Hablar", "emoji": "💬", "example": "I speak Spanish." }
            ],
            "tip": "💡 'My name is' es más formal. 'I'm' es más casual y común en conversación."
          },
          "exercises": [
