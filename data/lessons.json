            "title": "Rutina de la Mañana",
            "explanation": "El presente simple se usa para hablar de rutinas diarias. Usamos verbos en forma base.",
            "grammar": "I + verbo base → I wake up (me despierto)\nI brush my teeth → Me cepillo los dientes\nI take a shower → Me doy una ducha\nI eat breakfast → Desayuno\nI go to school → Voy a la escuela",
            "vocabulary": [
              { "word": "Wake up", "translation": "Despertar(se)", "emoji": "⏰", "example": "I wake up at 7 AM." },
              { "word": "Brush teeth", "translation": "Cepillarse dientes", "emoji": "🪥", "example": "I brush my teeth every morning." },
              { "word": "Shower", "translation": "Ducha", "emoji": "🚿", "example": "I take a shower." },
              { "word": "Breakfast", "translation": "Desayuno", "emoji": "🍳", "example": "I eat breakfast at 8." },
              { "word": "Get dressed", "translation": "Vestirse", "emoji": "👕", "example": "I get dressed quickly." },
              { "word": "School", "translation": "Escuela", "emoji": "🏫", "example": "I go to school at 8." }
