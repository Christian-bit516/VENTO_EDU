          "xpReward": 20,
          "theory": {
            "title": "Saludos en Inglés",
            "explanation": "En inglés usamos distintos saludos según la hora del día y el nivel de formalidad.",
            "grammar": "Hello / Hi → informal\nGood morning → mañana\nGood afternoon → tarde\nGood evening → noche\nGoodbye / Bye → adiós",
            "vocabulary": [
              { "word": "Hello", "translation": "Hola", "emoji": "👋", "example": "Hello! How are you?" },
              { "word": "Goodbye", "translation": "Adiós", "emoji": "🚪", "example": "Goodbye! See you tomorrow!" },
              { "word": "Good morning", "translation": "Buenos días", "emoji": "🌅", "example": "Good morning, everyone!" },
              { "word": "Good night", "translation": "Buenas noches", "emoji": "🌙", "example": "Good night! Sleep well." },
